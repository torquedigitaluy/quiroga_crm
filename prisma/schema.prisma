// Quiroga Automóviles — CRM/ERP data model
// Money is always stored as Int cents (never Float). Exchange rates are stored
// as Int "micros" scaled by 10000 (e.g. 40.50 -> 405000) to avoid any floating
// point and to sidestep Decimal-on-SQLite ambiguity — see src/lib/money.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Enums ----------

enum PermissionEffect {
  GRANT
  REVOKE
}

enum Ubicacion {
  SAN_LUIS
  ZONAMERICA
  TALLER
  PROPIETARIO
}

enum TipoPropiedad {
  PROPIA
  PARTNER
  CONSIGNADO
}

enum EstadoVehiculo {
  APRONTANDO
  SENADO
  PUBLICADO
  VENDIDO
}

enum Moneda {
  UYU
  USD
}

enum LocalVenta {
  SAN_LUIS
  ZONAMERICA
  SHOPPINGCAR
  SANTA_ROSA
  AUTOBULEVAR
  PEDERNAL
  HOMERO_DE_LEON
  CONCORDE
  ROVEIRA
}

enum EstadoCredito {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum TipoDoc {
  CV
  CP
}

enum Escribano {
  ANALIA
  CAMILA
  SU_ESCRIBANO
}

enum CobroCliente {
  FINANCIADO_CASA
  CONTADO
  SU_ESCRIBANO
  OTRO
}

enum UbicacionTitulos {
  CLIENTE
  CAMILA
  ANALIA
  ADM_ZONA
}

enum FormaPago {
  CONTADO
  FINANCIADO
}

enum TipoPago {
  MENSUAL
  JORNAL
}

enum EstadoAsistencia {
  PRESENTE
  MEDIO_DIA
  LICENCIA
  ENFERMO
  AUSENTE
}

enum TipoComprobante {
  FACTURA
  NOTA_CREDITO
}

enum IvaRate {
  EXENTO
  DIEZ
  VEINTIDOS
}

enum Banco {
  BBVA
  SANTANDER
  GASTOS_TALLER
}

enum TipoMovimiento {
  INGRESO
  EGRESO
}

enum TipoDocumento {
  CONFORME
  PROMESA_COMPRAVENTA
  ORDEN_TALLER
}

enum TipoServicioTaller {
  MANTENIMIENTO
  DIAGNOSTICO
  REPARACION
  OTRO
}

enum EstadoOrdenTaller {
  PENDIENTE
  EN_PROCESO
  ESPERANDO_REPUESTOS
  ESPERANDO_APROBACION
  FINALIZADA
  ENTREGADA
  EN_DIAGNOSTICO
  EN_REPARACION
}

enum PrioridadOrden {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum CategoriaImagenOrden {
  INGRESO
  REPARACION
  FINALIZADO
  OTRA
}

enum FormaPagoRecibo {
  CONTADO
  TRANSFERENCIA
}

enum EstadoConforme {
  PENDIENTE
  PAGADO
  VENCIDO
}

// ---------- Auth & Permissions ----------

model User {
  id           String   @id @default(cuid())
  nombre       String
  email        String   @unique
  passwordHash String
  activo       Boolean  @default(true)
  esVendedor   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles                UserRole[]
  permissions          UserPermission[]
  ventas               Venta[]              @relation("VendedorVentas")
  ventasAccesorio      VentaAccesorio[]     @relation("VendedorVentasAccesorio")
  vehiculosResponsable Vehiculo[]           @relation("VehiculoResponsable")
  passwordResetTokens  PasswordResetToken[]
  loginVerifications   LoginVerification[]
  ordenesComoTecnico   OrdenTaller[]        @relation("TecnicoResponsableOrden")
  ordenesComoRevisor   OrdenTaller[]        @relation("RevisorOrden")
  ordenesCreadas       OrdenTaller[]        @relation("CreadorOrden")
  promesasCreadas      PromesaCompraventa[] @relation("CreadorPromesa")
  valesCreados         Vale[]               @relation("CreadorVale")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Verificación en dos pasos por email: primero se valida usuario/contraseña
// (fuera del provider de NextAuth) y se manda un código de 6 dígitos: recién
// al confirmarlo se emite un "ticket" de un solo uso, de vida muy corta, que
// es lo único que el provider Credentials acepta para emitir la sesión real.
// Así un POST directo a la API de NextAuth con solo email+password nunca
// alcanza para loguearse sin pasar por el código.
model LoginVerification {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash           String
  codeExpiresAt      DateTime
  codeUsedAt         DateTime?
  otpTicketHash      String?
  otpTicketExpiresAt DateTime?
  otpTicketUsedAt    DateTime?
  createdAt          DateTime  @default(now())

  @@index([userId])
  @@index([otpTicketHash])
}

model Role {
  id          String  @id @default(cuid())
  key         String  @unique
  nombre      String
  descripcion String?

  permissions RolePermission[]
  users       UserRole[]
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Permission {
  id    String @id @default(cuid())
  key   String @unique
  label String
  grupo String

  roles RolePermission[]
  users UserPermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserPermission {
  userId       String
  permissionId String
  effect       PermissionEffect
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

// ---------- Shared spine: Vehiculo & Cliente ----------

model Vehiculo {
  id                  String         @id @default(cuid())
  marca               String
  modelo              String
  version             String?
  anio                Int?
  color               String?
  km                  Int?
  motor               String?
  transmision         String?
  ubicacion           Ubicacion      @default(ZONAMERICA)
  precioVentaUsdCents Int?
  matricula           String?
  padron              String?
  chasis              String?
  patenteCuotaCents   Int?
  patenteAnualCents   Int?
  propietario         String?
  tipoPropiedad       TipoPropiedad  @default(PROPIA)
  segundaLlave        Boolean        @default(false)
  ubicacionLibreta    String?
  comentarios         String?
  esVehiculo          Boolean        @default(true)
  estado              EstadoVehiculo @default(APRONTANDO)
  fechaIngreso        DateTime       @default(now())
  // Orden manual del listado de stock (drag & drop). Menor = más arriba.
  orden               Int            @default(0)
  responsableId       String?
  responsable         User?          @relation("VehiculoResponsable", fields: [responsableId], references: [id])
  archivedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  costeo               VehiculoCosteo?
  ventas               Venta[]
  ventasAccesorio      VentaAccesorio[]     @relation("AccesorioVentas")
  creditosBBVA         CreditoBBVA[]
  tramitesEscribania   EscribaniaTramite[]
  financiacionesTitulo FinanciacionTitulo[]
  financiacionesPropia FinanciacionPropia[]
  deudasCliente        DeudaCliente[]
  ordenesTaller        OrdenTaller[]
  promesas             PromesaCompraventa[]

  @@index([matricula])
  @@index([marca])
  @@index([estado])
  @@index([orden])
}

model Cliente {
  id        String   @id @default(cuid())
  nombre    String
  apellido  String?
  ci        String?
  contacto  String?
  direccion String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ventas               Venta[]
  ventasAccesorio      VentaAccesorio[]
  creditosBBVA         CreditoBBVA[]
  tramitesEscribania   EscribaniaTramite[]
  financiacionesTitulo FinanciacionTitulo[]
  financiacionesPropia FinanciacionPropia[]
  deudas               DeudaCliente[]
  promesas             PromesaCompraventa[]
  vales                Vale[]

  @@index([nombre])
  @@index([ci])
}

// ---------- Costos de Vehículo ----------

model VehiculoCosteo {
  id                      String   @id @default(cuid())
  vehiculoId              String   @unique
  vehiculo                Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
  tipoCambioMicros        Int      @default(0) // 0 = usa Configuracion.tipoCambioGlobalMicros
  fechaCompra             DateTime?
  fechaPublicacion        DateTime?
  fechaVenta              DateTime?
  precioCompraUsdCents    Int      @default(0)
  valorPatenteUsdCents    Int      @default(0)
  cantCuotasPatentePagas  Int      @default(0)
  precioVentaRealUsdCents Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  gastos GastoLine[]
}

model GastoLine {
  id          String         @id @default(cuid())
  costeoId    String
  costeo      VehiculoCosteo @relation(fields: [costeoId], references: [id], onDelete: Cascade)
  descripcion String
  moneda      Moneda         @default(USD)
  montoCents  Int
  orden       Int            @default(0)
  createdAt   DateTime       @default(now())
}

// ---------- Ventas ----------

model Venta {
  id                     String     @id @default(cuid())
  vehiculoId             String?
  vehiculo               Vehiculo?  @relation(fields: [vehiculoId], references: [id])
  vehiculoExterno        String?
  clienteId              String?
  cliente                Cliente?   @relation(fields: [clienteId], references: [id])
  fechaSena              DateTime?
  senaUsdCents           Int        @default(0)
  fechaEntrega           DateTime?
  precioVentaUsdCents    Int
  vendedorId             String?
  vendedor               User?      @relation("VendedorVentas", fields: [vendedorId], references: [id])
  localVenta             LocalVenta @default(ZONAMERICA)
  propietarioVehiculo    String?
  comisionVentaUsdCents  Int        @default(0)
  comisionTituloPesosCents Int      @default(0)
  archivedAt             DateTime?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  promesas PromesaCompraventa[]

  @@index([fechaEntrega])
  @@index([vendedorId])
}

model VentaAccesorio {
  id                        String    @id @default(cuid())
  accesorioId               String?
  accesorio                 Vehiculo? @relation("AccesorioVentas", fields: [accesorioId], references: [id])
  accesorioExterno          String?
  clienteId                 String?
  cliente                   Cliente?  @relation(fields: [clienteId], references: [id])
  vendedorId                String?
  vendedor                  User?     @relation("VendedorVentasAccesorio", fields: [vendedorId], references: [id])
  fecha                     DateTime  @default(now())
  precioVentaCents          Int
  precioVentaMoneda         Moneda    @default(USD)
  comisionAccesorioCents    Int       @default(0)
  comisionAccesorioMoneda   Moneda    @default(USD)
  createdAt                 DateTime  @default(now())

  @@index([fecha])
  @@index([vendedorId])
}

// ---------- Créditos BBVA ----------

model CreditoBBVA {
  id                      String        @id @default(cuid())
  nombre                  String
  ci                      String?
  contacto                String?
  montoSolicitadoUsdCents Int
  fechaFirma              DateTime?
  estado                  EstadoCredito @default(PENDIENTE)
  vehiculoId              String?
  vehiculo                Vehiculo?     @relation(fields: [vehiculoId], references: [id])
  clienteId               String?
  cliente                 Cliente?      @relation(fields: [clienteId], references: [id])
  archivedAt              DateTime?
  createdAt               DateTime      @default(now())

  @@index([fechaFirma])
}

// ---------- Escribanía ----------

model EscribaniaTramite {
  id                  String           @id @default(cuid())
  vehiculoId          String?
  vehiculo            Vehiculo?        @relation(fields: [vehiculoId], references: [id])
  vehiculoExterno     String?
  clienteId           String?
  cliente             Cliente?         @relation(fields: [clienteId], references: [id])
  fecha               DateTime?
  tipoDoc             TipoDoc
  titulosCon          Escribano
  fechaFirma          DateTime?
  pagoEscribaniaCents Int              @default(0)
  pagoMoneda          Moneda           @default(USD)
  fechaPago           DateTime?
  cobroAlCliente      CobroCliente     @default(CONTADO)
  cobroMontoCents     Int              @default(0)
  fechaCobro          DateTime?
  fechaEntregaTitulos DateTime?
  ubicacionTitulos    UbicacionTitulos @default(CLIENTE)
  comentarios         String?
  archivedAt          DateTime?
  createdAt           DateTime         @default(now())

  @@index([fecha])
}

// ---------- Financiación de Títulos ----------

model FinanciacionTitulo {
  id                   String    @id @default(cuid())
  vehiculoId           String?
  vehiculo             Vehiculo? @relation(fields: [vehiculoId], references: [id])
  vehiculoExterno      String?
  clienteId            String?
  cliente              Cliente?  @relation(fields: [clienteId], references: [id])
  contacto             String?
  fechaVenta           DateTime?
  fechaFirma           DateTime?
  costoEscribaniaCents Int       @default(0)
  costoMoneda          Moneda    @default(USD)
  cartaDePago          Boolean   @default(false)
  formaPago            FormaPago @default(CONTADO)
  archivedAt           DateTime?
  createdAt            DateTime  @default(now())

  entregas EntregaTitulo[]
}

model EntregaTitulo {
  id                   String              @id @default(cuid())
  financiacionTituloId String
  financiacionTitulo   FinanciacionTitulo  @relation(fields: [financiacionTituloId], references: [id], onDelete: Cascade)
  numero               Int
  montoCents           Int
  fecha                DateTime?

  @@unique([financiacionTituloId, numero])
}

// ---------- Personal ----------

model Empleado {
  id                 String   @id @default(cuid())
  nombre             String
  apellido           String?
  tipoPago           TipoPago @default(MENSUAL)
  sueldoMensualCents Int?
  jornalDiarioCents  Int?
  activo             Boolean  @default(true)
  createdAt          DateTime @default(now())

  asistencias AsistenciaDia[]
  descuentos  DescuentoEmpleado[]
}

model AsistenciaDia {
  id         String           @id @default(cuid())
  empleadoId String
  empleado   Empleado         @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  fecha      DateTime
  estado     EstadoAsistencia @default(AUSENTE)

  @@unique([empleadoId, fecha])
}

model DescuentoEmpleado {
  id         String   @id @default(cuid())
  empleadoId String
  empleado   Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  fecha      DateTime
  concepto   String
  montoCents Int
  moneda     Moneda   @default(UYU)
  createdAt  DateTime @default(now())
}

// ---------- Financiación Propia (Jorge Autos) + Conformes + Deudas ----------

model FinanciacionPropia {
  id                      String    @id @default(cuid())
  clienteId               String?
  cliente                 Cliente?  @relation(fields: [clienteId], references: [id])
  nombre                  String
  contacto                String?
  vehiculoId              String?
  vehiculo                Vehiculo? @relation(fields: [vehiculoId], references: [id])
  montoFinanciadoUsdCents Int
  cantidadCuotas          Int
  montoCuotaUsdCents      Int
  fechaPrimeraCuota       DateTime?
  diaVencimientoMensual   Int       @default(10)
  archivedAt              DateTime?
  createdAt               DateTime  @default(now())

  cuotas    CuotaPropia[]
  conformes Conforme[]
  vales     Vale[]
}

model CuotaPropia {
  id                   String              @id @default(cuid())
  financiacionPropiaId String
  financiacionPropia   FinanciacionPropia  @relation(fields: [financiacionPropiaId], references: [id], onDelete: Cascade)
  numero               Int
  montoCents           Int
  fechaVencimiento     DateTime
  fechaPago            DateTime?
  pagada               Boolean             @default(false)
  conforme             Conforme?

  @@unique([financiacionPropiaId, numero])
}

model Conforme {
  id                   String             @id @default(cuid())
  financiacionPropiaId String
  financiacionPropia   FinanciacionPropia @relation(fields: [financiacionPropiaId], references: [id], onDelete: Cascade)
  cuotaId              String?            @unique
  cuota                CuotaPropia?       @relation(fields: [cuotaId], references: [id])
  montoCuotaCents      Int
  fechaVencimiento     DateTime
  cantidadCuotas       Int
  fechaPago            DateTime           @default(now())
  formaPago            FormaPagoRecibo    @default(CONTADO)

  // Réplica del documento físico "Conforme"
  montoEnLetras               String?
  acreedorNombre              String          @default("JORGE DANIEL QUIROGA SANABRIA")
  acreedorCi                  String          @default("3.283.578-8")
  numeroFactura               String?
  concepto                    String          @default("COMPRA VENTA AUTOMOTOR")
  fechaFactura                DateTime?
  deudorNombre                String?
  deudorCedula                String?
  deudorDomicilio             String?
  deudorDepartamentoDireccion String?
  deudorTelefono              String?
  estado                      EstadoConforme  @default(PAGADO)

  // Vehículo asociado al recibo (se elige del stock; se guarda desnormalizado
  // para que el comprobante quede fijo aunque después se edite el stock).
  vehiculoId       String?
  vehMarca         String?
  vehModelo        String?
  vehMatricula     String?

  createdAt            DateTime           @default(now())

  firmantes ConformeFirmante[]
}

model ConformeFirmante {
  id         String   @id @default(cuid())
  conformeId String
  conforme   Conforme @relation(fields: [conformeId], references: [id], onDelete: Cascade)
  nombre     String
  ci         String?
  orden      Int      @default(1)
}

model DeudaCliente {
  id         String   @id @default(cuid())
  clienteId  String?
  cliente    Cliente? @relation(fields: [clienteId], references: [id])
  nombre     String
  contacto   String?
  vehiculoId String?
  vehiculo   Vehiculo? @relation(fields: [vehiculoId], references: [id])
  matricula  String?
  concepto   String
  montoCents Int
  moneda     Moneda   @default(UYU)
  saldado    Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ---------- Contadora ----------

model GastoContadora {
  id                String          @id @default(cuid())
  tipoComprobante   TipoComprobante @default(FACTURA)
  fecha             DateTime
  numeroFactura     String?
  proveedor         String
  moneda            Moneda          @default(UYU)
  ivaRate           IvaRate         @default(VEINTIDOS)
  importeTotalCents Int
  createdAt         DateTime        @default(now())

  @@index([fecha])
}

// ---------- Bancos ----------

model CuentaBancaria {
  id                     String @id @default(cuid())
  nombre                 Banco  @unique
  saldoInicialPesosCents Int    @default(0)
  saldoInicialUsdCents   Int    @default(0)

  movimientos MovimientoBancario[]
}

model MovimientoBancario {
  id              String                     @id @default(cuid())
  cuentaId        String
  cuenta          CuentaBancaria             @relation(fields: [cuentaId], references: [id])
  fecha           DateTime
  detalle         String
  comentario      String?
  tipo            TipoMovimiento
  montoPesosCents Int                        @default(0)
  montoUsdCents   Int                        @default(0)
  categoria       String?
  transferenciaId String?
  transferencia   TransferenciaEntreCuentas? @relation(fields: [transferenciaId], references: [id])
  createdAt       DateTime                   @default(now())

  @@index([cuentaId, fecha])
}

model TransferenciaEntreCuentas {
  id                    String   @id @default(cuid())
  fecha                 DateTime
  cuentaOrigenId        String
  cuentaDestinoId       String
  montoPesosCents       Int      @default(0)
  montoUsdCents         Int      @default(0)
  comisionBancariaCents Int      @default(0)
  comentario            String?
  createdAt             DateTime @default(now())

  movimientos MovimientoBancario[]
}

// ---------- Documentos ----------

model DocumentoTemplate {
  id            String        @id @default(cuid())
  tipo          TipoDocumento @unique
  nombre        String
  contenidoBase String
  activo        Boolean       @default(true)
  updatedAt     DateTime      @updatedAt
}

// ---------- Promesa de Compraventa (réplica exacta del formulario en papel) ----------

model PromesaCompraventa {
  id     String @id @default(cuid())
  numero Int    @unique @default(autoincrement())

  ventaId    String?
  venta      Venta?   @relation(fields: [ventaId], references: [id])
  vehiculoId String?
  vehiculo   Vehiculo? @relation(fields: [vehiculoId], references: [id])
  clienteId  String?
  cliente    Cliente? @relation(fields: [clienteId], references: [id])

  fecha      DateTime @default(now())
  vendedores String?

  // Vehículo
  vehMarca     String?
  vehModelo    String?
  vehTipo      String?
  vehColor     String?
  vehAnio      Int?
  vehMatricula String?
  vehMotor     String?
  vehChasis    String?

  // Cliente
  clienteNombre      String?
  clienteApellido    String?
  clienteCi          String?
  clienteDomicilio   String?
  clienteCiudad      String?
  clienteContacto    String?
  clienteEstadoCivil String?
  clienteNombre2     String?
  clienteMail        String?

  // Condiciones de pago
  financia    Boolean @default(false)
  financiaCon String?

  senaUsdCents               Int?
  pagoRetiroUnidadUsdCents   Int?
  capitalFinanciadoUsdCents  Int?
  conformesUsdCents          Int?
  conformesCantidadCuotas    Int?
  conformesCuotaUsdCents     Int?
  valorTomaAutoUsdCents      Int?
  totalUsdCents              Int?

  // Documentación
  costoTitulosUsdCents         Int?
  costoTitulosMoneda           Moneda @default(USD)
  cartaPagoUsdCents             Int?
  cartaPagoMoneda               Moneda @default(USD)
  entregaCuentaTitulosUsdCents Int?
  entregaCuentaTitulosMoneda   Moneda @default(USD)

  // Seguro
  seguro       Boolean @default(false)
  aseguradora  String?
  cobertura    String?

  // Cesión de derechos
  cesionDerechos  Boolean @default(false)
  cesionANombreDe String?

  observaciones String?

  // Vehículo que se permuta
  permutaMarca     String?
  permutaModelo    String?
  permutaTipo      String?
  permutaColor     String?
  permutaLlaves    String?
  permutaAnio      Int?
  permutaMatricula String?
  permutaMotor     String?
  permutaChasis    String?

  creadoPorId String?
  creadoPor   User?   @relation("CreadorPromesa", fields: [creadoPorId], references: [id])
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clienteId])
  @@index([vehiculoId])
}

// ---------- Vale de financiación (documento único por plan, firmado en papel) ----------

model Vale {
  id     String @id @default(cuid())
  numero Int    @unique @default(autoincrement())

  financiacionPropiaId String?
  financiacionPropia   FinanciacionPropia? @relation(fields: [financiacionPropiaId], references: [id])
  clienteId            String?
  cliente              Cliente?            @relation(fields: [clienteId], references: [id])

  fecha DateTime @default(now())

  // Condiciones del plan
  condiciones             String?
  montoFinanciadoUsdCents Int?
  cantidadCuotas          Int?
  montoCuotaUsdCents      Int?
  diaVencimientoMensual   Int?
  fechaPrimeraCuota       DateTime?
  observaciones           String?

  // Vale legal. Los montos van en la moneda elegida; el monto en letras queda editable.
  moneda                    Moneda  @default(UYU)
  totalPesosCents           Int?
  totalEnLetras             String?
  capitalPrestadoPesosCents Int?
  montoCuotaPesosCents      Int?
  montoCuotaEnLetras        String?
  acreedores                String? @default("Georgina Villegas Castro, CI 4.785.148-0 y Jorge Daniel Quiroga Sanabria, CI 3.283.578-8")

  // Responsables del pago — hasta tres firmantes, cada uno con espacio en
  // blanco para firmar a mano sobre el impreso (sin firma digital).
  firmante1Nombre    String?
  firmante1Ci        String?
  firmante1Domicilio String?
  firmante2Nombre    String?
  firmante2Ci        String?
  firmante2Domicilio String?
  firmante3Nombre    String?
  firmante3Ci        String?
  firmante3Domicilio String?

  creadoPorId String?
  creadoPor   User?     @relation("CreadorVale", fields: [creadoPorId], references: [id])
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clienteId])
  @@index([financiacionPropiaId])
}

model OrdenTaller {
  id                 String             @id @default(cuid())
  numeroOrden        Int                @unique @default(autoincrement())
  prioridad          PrioridadOrden     @default(MEDIA)
  vehiculoId         String?
  vehiculo           Vehiculo?          @relation(fields: [vehiculoId], references: [id])
  vehiculoExterno    String?
  // Snapshot de los datos del vehículo al momento de la orden (independiente
  // del stock: el km/chasis pueden diferir o la orden puede no estar ligada
  // a ningún vehículo de stock).
  vehMarca           String?
  vehModelo          String?
  vehVersion         String?
  vehAnio            Int?
  vehColor           String?
  vehMatricula       String?
  vehKm              Int?
  vehChasis          String?
  clienteNombre      String?
  clienteTelefono    String?
  clienteDireccion   String?
  tipoServicio       TipoServicioTaller @default(MANTENIMIENTO)
  tiposServicio      String[]           @default([])
  tipoServicioOtro   String?
  fechaIngreso       DateTime
  fechaFinalizacion  DateTime?
  problema           String
  trabajosRealizados String?
  observaciones      String?
  manoDeObraCents    Int                @default(0)
  responsable        String?
  tecnicoResponsableId     String?
  tecnicoResponsable       User?      @relation("TecnicoResponsableOrden", fields: [tecnicoResponsableId], references: [id])
  tecnicoResponsableFecha  DateTime?
  revisadoPorId            String?
  revisadoPor              User?      @relation("RevisorOrden", fields: [revisadoPorId], references: [id])
  revisadoAprobado         Boolean?
  revisadoAt               DateTime?
  clienteFirmaDataUrl      String?
  clienteFirmaFecha        DateTime?
  creadoPorId              String?
  creadoPor                User?      @relation("CreadorOrden", fields: [creadoPorId], references: [id])
  estado             EstadoOrdenTaller  @default(PENDIENTE)
  archivedAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  repuestos OrdenTallerRepuesto[]
  gastos    OrdenTallerGasto[]
  checklist OrdenTallerChecklistItem[]
  imagenes  OrdenTallerImagen[]

  @@index([estado])
}

model OrdenTallerRepuesto {
  id              String      @id @default(cuid())
  ordenTallerId   String
  ordenTaller     OrdenTaller @relation(fields: [ordenTallerId], references: [id], onDelete: Cascade)
  codigo          String?
  descripcion     String
  cantidad        Int         @default(1)
  precioUnitCents Int         @default(0)
  moneda          Moneda      @default(UYU)
  createdAt       DateTime    @default(now())
}

model OrdenTallerGasto {
  id            String      @id @default(cuid())
  ordenTallerId String
  ordenTaller   OrdenTaller @relation(fields: [ordenTallerId], references: [id], onDelete: Cascade)
  descripcion   String
  montoCents    Int
  moneda        Moneda      @default(UYU)
  createdAt     DateTime    @default(now())
}

model OrdenTallerChecklistItem {
  id            String      @id @default(cuid())
  ordenTallerId String
  ordenTaller   OrdenTaller @relation(fields: [ordenTallerId], references: [id], onDelete: Cascade)
  tarea         String
  hecho         Boolean     @default(false)
  orden         Int         @default(0)
}

model OrdenTallerImagen {
  id            String                @id @default(cuid())
  ordenTallerId String
  ordenTaller   OrdenTaller           @relation(fields: [ordenTallerId], references: [id], onDelete: Cascade)
  categoria     CategoriaImagenOrden  @default(OTRA)
  dataUrl       String
  createdAt     DateTime              @default(now())
}

// ---------- Auditoría ----------

// Registro de cambios: quién hizo qué y cuándo. Se usa sobre todo para saber
// quién eliminó (o editó) un vehículo, gasto, venta, etc. No tiene FK a User
// para que el registro sobreviva aunque se borre el usuario.
model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  userNombre  String
  accion      String // CREAR | EDITAR | ELIMINAR
  entidad     String // "Vehículo", "Venta", "Gasto contadora", etc.
  entidadId   String?
  descripcion String
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([entidad])
}

// ---------- Configuración ----------

model Configuracion {
  id                       Int      @id @default(1)
  tipoCambioGlobalMicros   Int      @default(400000)
  nombreEmpresa            String   @default("Quiroga Automóviles")
  updatedAt                DateTime @updatedAt
}
